generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String
  role        String    @default("USER")
  weight      Int?      // kg
  height      Int?      // cm
  wetsuitSize String?   // XS-XXL
  createdAt   DateTime  @default(now())
  bookings    Booking[]
}

model Class {
  id          String    @id @default(cuid())
  title       String
  description String
  type        String    @default("GROUP")
  capacity    Int       @default(8)
  price       Float
  duration    Int       @default(90)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  sessions    Session[]
}

model Session {
  id        String    @id @default(cuid())
  classId    String
  date      DateTime
  time      String
  isActive  Boolean   @default(true)
  class     Class     @relation(fields: [classId], references: [id])
  bookings  Booking[]
}

model Booking {
  id           String   @id @default(cuid())
  userId       String
  sessionId    String
  participants Int      @default(1)
  status       String   @default("CONFIRMED")
  weight       Int?     // kg, solo para alquiler
  height       Int?     // cm, solo para alquiler
  wetsuitSize  String?  // XS-XXL, solo para alquiler
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
  session      Session  @relation(fields: [sessionId], references: [id])
}
